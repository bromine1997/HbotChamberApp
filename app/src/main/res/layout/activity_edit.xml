<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Activity.EditActivity">

    <!-- 기존 Guideline 유지 -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineHorizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_end="0dp" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineVertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.6" />

    <LinearLayout
        android:id="@+id/linearLayoutGraph"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@+id/guidelineHorizontal"
        app:layout_constraintEnd_toStartOf="@+id/guidelineVertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/chart"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginTop="20dp"
            android:layout_weight="1"
            android:background="@drawable/border"/>

        <!-- 버튼들을 위한 CardView -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:gravity="center"
                android:background="#E3F2FD">

                <android.widget.Button
                    android:id="@+id/btnOpen"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/round"
                    android:text="Open"
                    android:textColor="#ffffff"
                    android:textSize="24sp" />

                <android.widget.Button
                    android:id="@+id/btnNew"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/round"
                    android:text="New"
                    android:textColor="#ffffff"
                    android:textSize="24sp" />

                <android.widget.Button
                    android:id="@+id/btnSave"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/round"
                    android:text="Save"
                    android:textColor="#ffffff"
                    android:textSize="24sp" />

                <android.widget.Button
                    android:id="@+id/btnExit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/round"
                    android:text="EXIT"
                    android:textColor="#ffffff"
                    android:textSize="24sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Number of Sections를 위한 CardView -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:gravity="center"
                android:background="#E3F2FD">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/numberOfSectionsLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Number of Sections"
                        android:textColor="#1976D2"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/valueNumberOfSections"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="8dp"
                        android:background="@drawable/border"
                        android:inputType="number"
                        android:text="0"
                        android:textAlignment="center"
                        android:textSize="20sp" />


                    <android.widget.Button
                        android:id="@+id/buttonDecreaseSections"
                        android:layout_width="60dp"
                        android:layout_height="48dp"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/round"
                        android:text="-"
                        android:textColor="#ffffff"
                        android:textSize="20sp" />

                    <android.widget.Button
                        android:id="@+id/buttonIncreaseSections"
                        android:layout_width="60dp"
                        android:layout_height="48dp"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/round"
                        android:text="+"
                        android:textColor="#ffffff"
                        android:textSize="24sp" />

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>



    <!-- 오른쪽 컨트롤 섹션 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@+id/guidelineHorizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/guidelineVertical"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Control Section Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/controlSectionCard"
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:layout_margin="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="8dp"
                android:background="#E3F2FD">

                <TextView
                    android:id="@+id/controlSectionLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Control Section"
                    android:textAlignment="center"
                    android:textColor="#1976D2"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/valueControlSection"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="1.0"
                        android:textAlignment="center"
                        android:textSize="24sp"
                        android:padding="4dp"
                        android:background="#FFFFFF"
                        android:layout_marginEnd="8dp"/>

                    <android.widget.Button
                        android:id="@+id/buttonDecreaseControlSection"
                        android:layout_width="60dp"
                        android:layout_height="48dp"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/round"
                        android:text="-"
                        android:textColor="#ffffff"
                        android:textSize="20sp" />

                    <android.widget.Button
                        android:id="@+id/buttonIncreaseControlSection"
                        android:layout_width="55dp"
                        android:layout_height="48dp"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/round"
                        android:text="+"
                        android:textColor="#ffffff"
                        android:textSize="20sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- End Pressure Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:layout_margin="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="8dp"
                android:background="#E3F2FD">

                <TextView
                    android:id="@+id/controlEndPressure"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="End Pressure (ATA)"
                    android:textAlignment="center"
                    android:textColor="#1976D2"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/valueEndPressure"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="1.0"
                        android:textAlignment="center"
                        android:textSize="24sp"
                        android:padding="4dp"
                        android:background="#FFFFFF"
                        android:layout_marginEnd="8dp"/>

                    <android.widget.Button
                        android:id="@+id/buttonDecreaseEndPressure"
                        android:layout_width="60dp"
                        android:layout_height="48dp"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/round"
                        android:text="-"
                        android:textColor="#ffffff"
                        android:textSize="20sp" />

                    <android.widget.Button
                        android:id="@+id/buttonIncreaseEndPressure"
                        android:layout_width="60dp"
                        android:layout_height="48dp"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/round"
                        android:text="+"
                        android:textColor="#ffffff"
                        android:textSize="20sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Time Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:layout_margin="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="8dp"
                android:background="#E3F2FD">

                <TextView
                    android:id="@+id/controlTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Time (min)"
                    android:textAlignment="center"
                    android:textColor="#1976D2"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/valueTime"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="1.0"
                        android:textAlignment="center"
                        android:textSize="24sp"
                        android:padding="4dp"
                        android:background="#FFFFFF"
                        android:layout_marginEnd="8dp"/>

                    <android.widget.Button
                        android:id="@+id/buttonDecreaseTime"
                        android:layout_width="60dp"
                        android:layout_height="48dp"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/round"
                        android:text="-"
                        android:textColor="#ffffff"
                        android:textSize="20sp" />

                    <android.widget.Button
                        android:id="@+id/buttonIncreaseTime"
                        android:layout_width="60dp"
                        android:layout_height="48dp"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/round"
                        android:text="+"
                        android:textColor="#ffffff"
                        android:textSize="20sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Flow Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:layout_margin="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="8dp"
                android:background="#E3F2FD">

                <TextView
                    android:id="@+id/controlFlow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Flow"
                    android:textAlignment="center"
                    android:textColor="#1976D2"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/valueFlowset"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="1.0"
                        android:textAlignment="center"
                        android:textSize="24sp"
                        android:padding="4dp"
                        android:background="#FFFFFF"
                        android:layout_marginEnd="8dp"/>

                    <android.widget.Button
                        android:id="@+id/buttonDecreaseFlow"
                        android:layout_width="60dp"
                        android:layout_height="48dp"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/round"
                        android:text="-"
                        android:textColor="#ffffff"
                        android:textSize="20sp" />

                    <android.widget.Button
                        android:id="@+id/buttonIncreaseFlow"
                        android:layout_width="60dp"
                        android:layout_height="48dp"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/round"
                        android:text="+"
                        android:textColor="#ffffff"
                        android:textSize="20sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <!-- 테이블 부분 -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/border"
            android:layout_margin="6dp">

            <TableLayout
                android:id="@+id/Table"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="*">

                <TableRow
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/INDEX"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/border"
                        android:text="#"
                        android:textAlignment="center"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/StartPoint"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/border"
                        android:text="START P"
                        android:textAlignment="center"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/EndPoint"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/border"
                        android:text="END P"
                        android:textAlignment="center"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/time"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/border"
                        android:text="time"
                        android:textAlignment="center"
                        android:textSize="20sp" />
                </TableRow>
            </TableLayout>
        </ScrollView>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
